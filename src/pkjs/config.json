      {
        "type": "toggle",
        "label": "Startup Animation",
        "messageKey": "AnimOn",
        "defaultValue": true
      },
      {
        "type": "toggle",
        "label": "Gravity Mode",
        "capabilities": ["MICROPHONE"],
        "description": "If switched on, 2 shakes/taps less than 1 second apart will start (or stop) gravity mode",
        "messageKey": "GravityModeOn",
        "defaultValue": false
      },
      {
        "type": "slider",
        "label": "Gravity Mode Timeout",
        "capabilities": ["MICROPHONE"],
        "description": "Seconds gravity mode stays on",
        "messageKey": "GravModeTimeout",
        "defaultValue": 10,
        "min": 5,
        "max": 60,
        "step": 5
      },
      {
        "type": "slider",
        "label": "Gravity Mode Friction",
        "capabilities": ["MICROPHONE"],
        "description": "Higher values = less friction (or mroe retained velocity). Default = 82",
        "messageKey": "FrictionVal",
        "defaultValue": 82,
        "min": 30,
        "max": 96,
        "step": 2
      },
      {
        "type": "toggle",
        "label": "Digital Time Visible",
        "messageKey": "ShowTime",
        "defaultValue": true
      },
      {
        "type": "toggle",
        "label": "Digital Time Style",
        "messageKey": "HoursCentre",
        "description": "Off = Minutes in centre, On = Hours in centre",
        "defaultValue": true
      },
      {
        "type": "toggle",
        "messageKey": "showlocalAMPM",
        "label": "AM/PM Visible",
        "description": "Applies only when 12h time selected in watch settings",
        "defaultValue": true
      },
      {
        "type": "toggle",
        "label": "Add leading zero to 12h time",
        "messageKey": "AddZero12h",
        "defaultValue": false
      },
      {
        "type": "toggle",
        "label": "Remove leading zero from 24h time",
        "messageKey": "RemoveZero24h",
        "defaultValue": false
      },
      {
        "type": "toggle",
        "label": "Battery Visible",
        "messageKey": "EnableBattery",
        "defaultValue": true
      },
      {
        "type": "toggle",
        "label": "Battery Style",
        "description": "Off = Bar, On = Arc",
        "messageKey": "BatteryArc",
        "defaultValue": false
      },
      {
        "type": "toggle",
        "label": "Major Ticks Visible",
        "messageKey": "EnableMajorTick",
        "defaultValue": true
      },
      {
        "type": "toggle",
        "label": "Minor Ticks Visible",
        "messageKey": "EnableMinorTick",
        "defaultValue": true
      },
      {
        "type": "toggle",
        "messageKey": "VibeOn",
        "label": "Vibrate on Bluetooth disconnect during Quiet Time",
        "description": "If set to off, will still vibrate on disconnect, but not during quiet time",
        "defaultValue": false
      }
